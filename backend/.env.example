# Server Configuration
PORT=3001
NODE_ENV=development

# Database Settings (PostgreSQL)
# For local Docker Compose, use: postgresql://postgres:postgres@localhost:5432/deskguard?schema=public
# Inside Docker Compose, use: postgresql://postgres:postgres@postgres:5432/deskguard?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deskguard?schema=public"

# Redis Cache Settings
# For local dev, use: redis://localhost:6379
# Inside Docker Compose, use: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# Security & CORS
FRONTEND_URL="http://localhost:3000"
